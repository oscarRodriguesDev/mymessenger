generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String               @id @default(uuid())
  authId                String               @unique
  username              String               @unique
  fullName              String
  email                 String               @unique
  phone                 String?              @unique
  phoneVerified         Boolean              @default(false)
  discoverableByPhone   Boolean              @default(true)
  discoverableByUsername Boolean              @default(true)
  avatarUrl             String?
  bio                   String?
  lastSeenAt            DateTime?
  readReceiptEnabled    Boolean              @default(true)
  typingIndicatorEnabled Boolean             @default(true)       // #11 opcional
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  sentMessages          Message[]            @relation("SentMessages")
  contacts              Contact[]            @relation("UserContacts")
  contactOf             Contact[]            @relation("ContactOf")
  blockedUsers          BlockedUser[]        @relation("UserBlocked")
  blockedBy             BlockedUser[]        @relation("BlockedBy")
  conversationMembers   ConversationMember[]
  messageReads          MessageRead[]
  devices               Device[]
  ownedConversations    Conversation[]       @relation("ConversationOwner")
  webSessions           WebSession[]
  reactions             Reaction[]
  sentVibes             VibeSignal[]         @relation("SentVibes")
  receivedVibes         VibeSignal[]         @relation("ReceivedVibes")

  @@index([username])
  @@index([email])
  @@index([phone])
  @@index([authId])
}

model Contact {
  id          String   @id @default(uuid())
  userId      String
  contactId   String
  status      String   @default("accepted") // pending, accepted, rejected
  createdAt   DateTime @default(now())

  user        User     @relation("UserContacts", fields: [userId], references: [id], onDelete: Cascade)
  contact     User     @relation("ContactOf", fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([userId, contactId])
  @@index([userId])
  @@index([contactId])
  @@index([status])
  @@map("contacts")
}

model BlockedUser {
  id              String   @id @default(uuid())
  userId          String
  blockedUserId   String
  createdAt       DateTime @default(now())

  user            User     @relation("UserBlocked", fields: [userId], references: [id], onDelete: Cascade)
  blockedUser     User     @relation("BlockedBy", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@unique([userId, blockedUserId])
  @@index([userId])
  @@index([blockedUserId])
  @@map("blocked_users")
}

model Conversation {
  id          String               @id @default(uuid())
  type        String
  name        String?
  avatarUrl   String?
  ownerId     String?
  isEphemeral Boolean              @default(false)              // #15 chat efêmero
  defaultTTL  Int?                                              // #15 TTL padrão (segundos)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  owner       User?                @relation("ConversationOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  members     ConversationMember[]
  messages    Message[]

  @@index([type])
  @@index([ownerId])
  @@map("conversations")
}

model ConversationMember {
  id              String       @id @default(uuid())
  conversationId  String
  userId          String
  role            String       @default("member")
  joinedAt        DateTime     @default(now())

  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
  @@map("conversation_members")
}

enum MessageStatus {
  nao_enviada
  enviada
  recebida
  lida
}

model Message {
  id              String           @id @default(uuid())
  conversationId  String
  senderId        String
  type            String
  text            String?
  fileUrl         String?
  status          MessageStatus    @default(enviada)
  clientMessageId String?                                       // #13 dedup (único por sender)
  expiresAt       DateTime?                                     // #14 TTL mensagem
  mimeType        String?                                       // #20 tipo da mídia
  fileSize        Int?                                          // #20 tamanho do arquivo (bytes)
  fileName        String?                                       // #20 nome original do arquivo
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  conversation    Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender          User             @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  reads           MessageRead[]
  reactions       Reaction[]

  @@unique([senderId, clientMessageId])                         // #13
  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt(sort: Desc)])
  @@index([status])
  @@index([clientMessageId])
  @@map("messages")
}

model MessageStatusEvent {
  id              String   @id @default(uuid())
  messageId       String
  conversationId  String
  status          String
  createdAt       DateTime @default(now())

  @@index([conversationId])
  @@index([createdAt(sort: Desc)])
  @@map("message_status_events")
}

model MessageRead {
  id          String   @id @default(uuid())
  messageId   String
  userId      String
  readAt      DateTime @default(now())

  message     Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([userId])
  @@map("message_reads")
}

model Reaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model Device {
  id          String   @id @default(uuid())
  userId      String
  platform    String
  pushToken   String
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([pushToken])
  @@map("devices")
}

enum QrAuthStatus {
  pending
  confirmed
  expired
}

model QrAuthSession {
  id        String        @id @default(uuid())
  token     String        @unique
  userId    String?
  authId    String?
  status    QrAuthStatus  @default(pending)
  userAgent String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  expiresAt DateTime

  @@index([token])
  @@index([status])
  @@index([expiresAt])
  @@map("qr_auth_sessions")
}

model WebSession {
  id        String   @id @default(uuid())
  userId    String
  authId    String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([authId])
  @@index([expiresAt])
  @@map("web_sessions")
}

model VibeSignal {
  id              String   @id @default(uuid())
  senderId        String
  receiverId      String
  conversationId  String?
  type            String   @default("buzz") // "buzz", "poke", "wave", "heartbeat", "fire"
  createdAt       DateTime @default(now())

  sender          User     @relation("SentVibes", fields: [senderId], references: [id], onDelete: Cascade)
  receiver        User     @relation("ReceivedVibes", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([receiverId])
  @@index([conversationId])
  @@index([createdAt(sort: Desc)])
  @@map("vibe_signals")
}
